# 1. إخفاء معلومات السيرفر
ServerSignature Off

# تحديد ترميز الحروف الافتراضي
AddDefaultCharset UTF-8

<IfModule mod_headers.c>
    # إخفاء ترويسة X-Powered-By (إذا كان السيرفر يسمح بذلك)
    Header unset X-Powered-By
    Header always unset X-Powered-By

    # 2. ترويسات الأمان (Security Headers)
    # منع وضع الموقع داخل إطار بالكامل
    Header set X-Frame-Options "DENY"

    # منع المتصفح من تخمين نوع الملفات
    Header set X-Content-Type-Options "nosniff"

    # سياسة الإحالة للخصوصية
    Header set Referrer-Policy "strict-origin-when-cross-origin"

    # تفعيل فلتر الحماية ضد الـ XSS
    Header set X-XSS-Protection "1; mode=block"

    # إجبار المتصفح على استخدام HTTPS
    Header set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

    # سياسة التحكم في ميزات المتصفح
    Header set Permissions-Policy "camera=(), microphone=(), geolocation=()"
</IfModule>

# 3. إعدادات توجيه الـ Single Page Application (React/Vite)
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /
    RewriteRule ^index\.html$ - [L]
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule . /index.html [L]
</IfModule>

# 4. إعدادات الـ Caching لملفات الموقع
<IfModule mod_expires.c>
    ExpiresActive On
    
    # لا تقم بعمل كاش لملف الـ HTML لضمان وصول التحديثات
    ExpiresByType text/html "access plus 0 seconds"
    
    # كاش قوي لملفات التصميم والجافاسكريبت (Vite يقوم بتغيير اسمها تلقائياً عند التحديث)
    ExpiresByType text/css "access plus 1 year"
    ExpiresByType application/javascript "access plus 1 year"
    
    # كاش للصور
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType image/x-icon "access plus 1 year"
</IfModule>
